			"separators": [
				{
					"id": "aanwijzing-1",
					"name": "Aanwijzing",
					"description": "Bijvoorbeeld: \"Aanwijzing 1.1. Reikwijdte\"",
					"code": "^Aanwijzing ([0-9]+\\.[0-9]+[a-z]?)\\. (.*)$",
					"type": "aanwijzing",
					"label": "Aanwijzing",
					"numbering": "$1",
					"title": "$2",
					"@type": "choppr:Separator"
				},
				{
					"id": "afkorting",
					"name": "Afkorting",
					"description": "Bijvoorbeeld: \"amvb algemene maatregel van bestuur\"",
					"code": "^([a-zA-Z\\-]+\\s?[a-zA-Z]+?\\.?)\\s{2}",
					"type": "afkorting",
					"label": "Afkorting",
					"numbering": "$1",
					"title": "$2",
					"@type": "choppr:Separator"
				},
				{
					"id": "afkortingen",
					"name": "Afkortingen",
					"description": "Een lijst met afkortingen.",
					"code": "^Afkortingen$",
					"type": "Afkortingen",
					"label": "Afkortingen",
					"numbering": "",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "artikel",
					"name": "Artikel",
					"description": "Artikel",
					"code": "^Artikel\\s(.+)$",
					"type": "Artikel",
					"label": "Artikel",
					"numbering": "$1",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "genaamd-lid",
					"name": "Genaamd lid",
					"description": "Bijvoorbeeld: \"Eerste lid.\"",
					"code": "^([a-zA-Z]+) lid\\.|^(.+) lid: [a-zA-Z]+\\.",
					"type": "lid",
					"label": "Lid",
					"numbering": "$1$2",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "graad",
					"name": "Graad",
					"description": "Onderdeel aangeduid door een nummer en het karakter °",
					"code": "^\\t\\t*(\\d)[°]\\..*$",
					"type": "Graad",
					"label": "$1°.",
					"numbering": "$1",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "hoofdstuk",
					"name": "Hoofdstuk",
					"description": "Hoofdstuk",
					"code": "^Hoofdstuk\\s(.*)\\.(.*)$",
					"type": "Hoofdstuk",
					"label": "Hoofdstuk $1. $2",
					"numbering": "$1",
					"title": "$2",
					"@type": "choppr:Separator"
				},
				{
					"id": "lid",
					"name": "Lid",
					"description": "Genummerd lid zonder het woord Lid",
					"code": "^\\t?(\\d*)\\.\\s(.*)",
					"type": "Lid",
					"label": "Lid $1.",
					"numbering": "$1",
					"title": "$2",
					"@type": "choppr:Separator"
				},
				{
					"id": "onderdeel-1-2",
					"name": "Onderdeel",
					"description": "Bijvoorbeeld: \"Onderdeel a:\"",
					"code": "^Onderdeel\\s([a-zA-Z])[\\.:]",
					"type": "onderdeel",
					"label": "Onderdeel",
					"numbering": "$1",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "opsomming",
					"name": "Opsomming *",
					"description": "Opsomming aangeduid met een *",
					"code": "^\\t+\\*(.*)$",
					"type": "Opsomming",
					"label": "opsomming",
					"numbering": "",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "opsomming-1",
					"name": "Opsomming -",
					"description": "Opsomming aangeduid met een - of een –",
					"code": "^\\t+[−–]+[\\.]?\\t",
					"type": "opsomming",
					"label": "Opsomming",
					"numbering": "",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "paragraaf",
					"name": "Paragraaf",
					"description": "Paragraaf",
					"code": "^§ ([0-9]+\\.?[0-9]+)\\.?(.*)$",
					"type": "Paragraaf",
					"label": "Paragraaf",
					"numbering": "$1",
					"title": "$2",
					"@type": "choppr:Separator"
				},
				{
					"id": "sentence-1",
					"name": "Zin",
					"description": "Alle zinnen",
					"code": "(?<!\\w\\.\\w.)(?<![A-Z][a-z]\\.)(?<=\\.|\\?)\\s",
					"type": "zin",
					"label": "Zin",
					"numbering": "",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "sub",
					"name": "Sub",
					"description": "Onderverdeling aangeduid door een letter.",
					"code": "^\\t\\t*([a-zA-Z])\\.",
					"type": "Sub",
					"label": "Sub $1",
					"numbering": "$1",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "toelichting",
					"name": "Toelichting",
					"description": "Toelichting bij een aanwijzing of artikel.",
					"code": "^Toelichting$",
					"type": "toelichting",
					"label": "Toelichting",
					"numbering": "",
					"title": "",
					"@type": "choppr:Separator"
				},
				{
					"id": "voorbeeld",
					"name": "Voorbeeld",
					"description": "Bijvoorbeeld: \"Voorbeeld bij het eerste lid.\"",
					"code": "^Voorbeeld.*$",
					"type": "voorbeeld",
					"label": "Voorbeeld",
					"numbering": "",
					"title": "",
					"@type": "choppr:Separator"
				}
			]
		},
