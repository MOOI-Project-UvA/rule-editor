# --- Shared auth/session configuration ---
# For Docker Compose env files, Argon2 hashes must escape '$' as '$$'.
# The helper script auth-service/scripts/generate_auth_user.py handles this automatically.
AUTH_DEBUG=false
AUTH_USERS_JSON={"editor":"paste-argon2-hash-here"}
AUTH_SESSION_SECRET=replace-with-long-random-secret
AUTH_SESSION_TTL_SECONDS=28800
AUTH_COOKIE_NAME=rule_editor_session
AUTH_COOKIE_SECURE=false
AUTH_ALLOWED_ORIGINS=http://localhost:5137,http://localhost:5173,http://localhost:8888

# --- MongoDB initialization and app credentials ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me-root-password
MONGO_INITDB_DATABASE=rule_editor
APP_DB_USER=rule_editor_app
APP_DB_PASSWORD=change-me-app-password