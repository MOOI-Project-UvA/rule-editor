# Self-hosted Netlify runtime config (no Netlify SaaS required)
# Copy to deploy/netlify/netlify.env and fill values as needed.

# Recommended for protected routes/edge checks
X_API_KEY=
ALLOWED_DOMAINS=

# Optional: Triply-backed features (source/task read-write)
TRIPLY_KEY_R=
TRIPLY_KEY_W=
TRIPLY_ENDPOINT=

# Optional: frontend API key and runtime routing values
VITE_X_API_KEY=
VITE_AUTH_ENABLED=true
VITE_AUTH_API_BASE_URL=
VITE_EFLINT_API_BASE_URL=
VITE_EFLINT_EXECUTE_URL=

# Optional metadata
VITE_VERSION=
VITE_REPOSITORY_URL=
VITE_BRANCH=

# Optional: FLINT translation backend used by generate-eflint function
FLINT_TRANSLATION_URL=
