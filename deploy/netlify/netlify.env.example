# Self-hosted Netlify runtime config (local/VM)
# Copy this file to netlify.env and fill what you need.

# Recommended for protected routes/edge checks
X_API_KEY=
ALLOWED_DOMAINS=

# Optional: Triply-backed features (source/task read-write)
TRIPLY_KEY_R=
TRIPLY_KEY_W=
TRIPLY_ENDPOINT=

# Optional: frontend API key and runtime routing values
VITE_X_API_KEY=
VITE_AUTH_ENABLED=true
VITE_AUTH_API_BASE_URL=http://localhost:8101
VITE_EFLINT_API_BASE_URL=http://localhost:8000
VITE_MONGO_API_BASE_URL=http://localhost:8102
# Optional: leave empty to use same-origin /execute and /repl/* routes
VITE_EFLINT_EXECUTE_URL=

# Optional metadata
VITE_VERSION=
VITE_REPOSITORY_URL=
VITE_BRANCH=
